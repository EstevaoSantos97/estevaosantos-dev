---
import Layout from './Layout.astro';
import { getLangFromUrl, useTranslations } from '../i18n';

const { title, number, summary, tags } = Astro.props.frontmatter;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const backHref = lang === "en" ? "/#work" : "/pt#work";
---

<Layout title={`${title} — estevaosantos.dev`} lang={lang}>
  <article class="border-b border-white/5">
    <div class="max-w-3xl mx-auto px-6 py-24 md:py-32">
      
      <a 
        href={backHref}
        class="text-sm text-muted hover:text-accent transition-colors inline-flex items-center gap-2 mb-12"
      >
        <span aria-hidden="true">←</span>
        {t.caseStudy.backLink}
      </a>

      <p class="font-mono text-sm text-accent mb-3">
        {t.work.title} / {number}
      </p>
      
      <h1 class="font-display text-4xl md:text-6xl font-extrabold uppercase tracking-tight leading-[0.95] mb-6">
        {title}
      </h1>
      
      <p class="text-xl text-ink/80 leading-relaxed mb-8">
        {summary}
      </p>
      
      <div class="flex flex-wrap gap-2 font-mono text-xs mb-16">
        {tags.map((tag) => (
          <span class="px-2.5 py-1 bg-white/5 text-muted border border-white/10 rounded-sm">
            {tag}
          </span>
        ))}
      </div>

      <div class="prose-case">
        <slot />
      </div>

    </div>
  </article>
</Layout>
