---
import { useTranslations } from "../i18n";
import type { Locale } from "../i18n";

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="experience" class="border-b border-white/5">
  <div class="max-w-6xl mx-auto px-6 py-24 md:py-32">
    
    <h2 class="font-display text-3xl md:text-4xl font-bold uppercase tracking-tight">
      {t.experience.title}
    </h2>
    <div class="h-px w-12 bg-accent mt-4 mb-16" aria-hidden="true"></div>

    <div class="space-y-16">
      {t.experience.currentRoles.map((r) => (
        <article class="grid grid-cols-1 md:grid-cols-[180px_1fr] gap-4 md:gap-12">
          
          <p class="text-xs uppercase tracking-widest text-muted md:pt-2">
            {r.period}
          </p>
          
          <div>
            <h3 class="font-display text-2xl md:text-3xl font-bold uppercase tracking-tight">
              {r.company}
              <span class="font-sans text-base font-normal normal-case tracking-normal text-muted">
                · {r.role}
              </span>
            </h3>
            
            <ul class="mt-6 space-y-3 text-base text-ink/90 leading-relaxed">
              {r.bullets.map((b) => (
                <li class="flex gap-3">
                  <span class="text-accent shrink-0 select-none" aria-hidden="true">→</span>
                  <span>{b}</span>
                </li>
              ))}
            </ul>
            
            <div class="mt-6 flex flex-wrap gap-2 font-mono text-xs">
              {r.tags.map((tag) => (
                <span class="px-2.5 py-1 bg-white/5 text-muted border border-white/10 rounded-sm">
                  {tag}
                </span>
              ))}
            </div>
          </div>
          
        </article>
      ))}
    </div>

    <details class="group mt-16">
      <summary class="flex items-center cursor-pointer py-4 border-t border-white/5 hover:bg-white/[0.02] transition-colors">
        <span class="font-display text-xl font-bold uppercase tracking-tight text-ink group-hover:text-accent transition-colors">
          {t.experience.earlierTitle}
        </span>
        <span class="ml-3 text-sm text-muted">
          ({t.experience.earlierRoles.length} {t.experience.positions})
        </span>
        <span class="accordion-arrow ml-auto text-accent text-lg" aria-hidden="true">↓</span>
      </summary>

      <div class="mt-8 space-y-6">
        {t.experience.earlierRoles.map((r) => (
          <article class="grid grid-cols-1 md:grid-cols-[180px_1fr] gap-2 md:gap-12 py-4 border-t border-white/5">
            <p class="text-xs uppercase tracking-widest text-muted md:pt-1">
              {r.period}
            </p>
            <div>
              <h4 class="text-base font-medium text-ink">
                {r.company}
                <span class="font-normal text-muted"> · {r.role}</span>
              </h4>
              <p class="mt-1 text-sm text-muted leading-relaxed">
                {r.line}
              </p>
            </div>
          </article>
        ))}
      </div>
    </details>

  </div>
</section>
