---
import { useTranslations } from "../i18n";
import type { Locale } from "../i18n";

interface Props {
  lang: Locale;
}

const {lang} = Astro.props;
const t = useTranslations(lang);
---

<section class="border-b border-white/5">
  <div class="max-w-6xl mx-auto px-6 py-32 md:py-40">
    
    <p class="text-xs font-medium uppercase tracking-widest text-muted mb-8">
      {t.hero.subtitle}
    </p>

    <h1 class="font-display font-extrabold uppercase tracking-tight leading-[0.95] text-6xl md:text-8xl max-w-5xl">
      {t.hero.headline} <span class="text-accent">{t.hero.headlineAccent}</span>.
    </h1>

    <p class="mt-8 text-lg text-muted max-w-2xl leading-relaxed">
      {t.hero.description}
    </p>

    <div class="mt-12 flex flex-wrap items-center gap-4">
      <a 
        href="#work" 
        class="inline-flex items-center gap-2 px-6 py-3 bg-accent text-paper font-medium hover:bg-accent/90 transition-colors"
      >
        {t.hero.cta}
        <span aria-hidden="true">→</span>
      </a>
      <a 
        href="#contact" 
        class="inline-flex items-center px-6 py-3 border border-white/10 text-ink font-medium hover:bg-white/5 transition-colors"
      >
        {t.hero.ctaSecondary}
      </a>
    </div>

  </div>
</section>