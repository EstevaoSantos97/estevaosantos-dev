---
import { useTranslations } from "../i18n";
import type { Locale } from "../i18n";

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const basePath = lang === "en" ? "" : `/${lang}`;
---

<section id="work" class="border-b border-white/5">
  <div class="max-w-6xl mx-auto px-6 py-24 md:py-32">
    
    <h2 class="font-display text-3xl md:text-4xl font-bold uppercase tracking-tight">
      {t.work.title}
    </h2>
    <div class="h-px w-12 bg-accent mt-4 mb-16" aria-hidden="true"></div>

    <div>
      {t.work.cases.map((c) => (
        <a href={`${basePath}/work/${c.slug}`}
          class="group block py-10 border-t border-white/5 hover:bg-white/[0.02] transition-colors"
        >
          <article class="grid grid-cols-[60px_1fr] md:grid-cols-[80px_1fr_auto] gap-x-4 md:gap-x-12 items-start">
            
            <span class="font-mono text-sm text-accent pt-2">
              {c.number}.
            </span>
            
            <div class="space-y-3">
              <h3 class="font-display text-2xl md:text-3xl font-bold uppercase tracking-tight group-hover:text-accent transition-colors">
                {c.title}
              </h3>
              <p class="text-base text-ink/80 leading-relaxed max-w-2xl">
                {c.summary}
              </p>
              <div class="flex flex-wrap gap-2 font-mono text-xs pt-2">
                {c.tags.map((tag) => (
                  <span class="px-2.5 py-1 bg-white/5 text-muted border border-white/10 rounded-sm">
                    {tag}
                  </span>
                ))}
              </div>
            </div>
            
            <span class="hidden md:flex items-center gap-2 text-sm text-muted group-hover:text-accent transition-colors pt-3 whitespace-nowrap">
              {t.work.readCase}
              <span aria-hidden="true">→</span>
            </span>
            
          </article>
        </a>
      ))}
      <div class="border-t border-white/5"></div>
    </div>

  </div>
</section>
