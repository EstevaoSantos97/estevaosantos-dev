---
import { useTranslations } from "../i18n";
import type { Locale } from "../i18n";

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="about" class="border-b border-white/5">
  <div class="max-w-6xl mx-auto px-6 py-24 md:py-32">
    
    <h2 class="font-display text-3xl md:text-4xl font-bold uppercase tracking-tight">
      {t.about.title}
    </h2>
    <div class="h-px w-12 bg-accent mt-4 mb-12" aria-hidden="true"></div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
      
      <div class="lg:col-span-2 space-y-6 text-lg text-ink/90 leading-relaxed">
        {t.about.bio.map((paragraph) => (
          <p>{paragraph}</p>
        ))}
      </div>

      <aside class="space-y-8">
        <div>
          <p class="text-xs uppercase tracking-widest text-muted mb-2">{t.about.availableForLabel}</p>
          <p class="text-ink">{t.about.availableForValue}</p>
        </div>
        <div>
          <p class="text-xs uppercase tracking-widest text-muted mb-2">{t.about.languagesLabel}</p>
          <p class="text-ink">{t.about.languagesValue}</p>
        </div>
        <div>
          <p class="text-xs uppercase tracking-widest text-muted mb-2">{t.about.locationLabel}</p>
          <p class="text-ink">{t.about.locationValue}</p>
        </div>
      </aside>

    </div>

  </div>
</section>
